meta {
  name: GET /:id/logs
  type: http
  seq: 3
}

get {
  url: {{api}}/devices/:id/logs?appKey={{appKey}}&secretKey={{secretKey}}&startTime=2025-10-02&endTime=2025-10-03&codes=mode,temp_current,temp_set,work_state
  body: none
  auth: none
}

params:query {
  appKey: {{appKey}}
  secretKey: {{secretKey}}
  startTime: 2025-10-02
  endTime: 2025-10-03
  codes: mode,temp_current,temp_set,work_state
}

params:path {
  id: {{deviceValve}}
}
